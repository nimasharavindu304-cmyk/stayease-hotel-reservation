<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="RevenueSummaryReport" pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="782"
              leftMargin="30" rightMargin="30" topMargin="30" bottomMargin="30"
              uuid="b2c3d4e5-f6a7-4b1c-9d2e-4f5a6b7c8d9e">

    <parameter name="FROM_DATE" class="java.sql.Timestamp"/>
    <parameter name="TO_DATE" class="java.sql.Timestamp"/>

    <queryString language="SQL">
        <![CDATA[
            SELECT b.booking_id,
                   CONCAT(g.first_name, ' ', g.last_name) AS guest_name,
                   r.room_number,
                   b.check_in_date,
                   b.check_out_date,
                   b.total_amount,
                   p.payment_method,
                   p.payment_date,
                   p.amount AS payment_amount
            FROM bookings b
            JOIN guests g ON b.guest_id = g.guest_id
            JOIN rooms  r ON b.room_id  = r.room_id
            LEFT JOIN payments p ON p.booking_id = b.booking_id
            WHERE p.payment_date BETWEEN $P{FROM_DATE} AND $P{TO_DATE}
            ORDER BY p.payment_date
        ]]>
    </queryString>

    <field name="booking_id" class="java.lang.Integer"/>
    <field name="guest_name" class="java.lang.String"/>
    <field name="room_number" class="java.lang.String"/>
    <field name="check_in_date" class="java.sql.Date"/>
    <field name="check_out_date" class="java.sql.Date"/>
    <field name="total_amount" class="java.math.BigDecimal"/>
    <field name="payment_method" class="java.lang.String"/>
    <field name="payment_date" class="java.sql.Timestamp"/>
    <field name="payment_amount" class="java.math.BigDecimal"/>

    <variable name="REVENUE_SUM" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{payment_amount}]]></variableExpression>
    </variable>

    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="0" width="782" height="26"/>
                <textElement>
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[StayEase Hotel - Revenue Report]]></text>
            </staticText>
            <textField pattern="dd-MMM-yyyy">
                <reportElement x="0" y="28" width="300" height="16"/>
                <textFieldExpression><![CDATA["Period: " + new java.text.SimpleDateFormat("dd-MMM-yyyy").format($P{FROM_DATE}) + " to " + new java.text.SimpleDateFormat("dd-MMM-yyyy").format($P{TO_DATE})]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="60" height="20"/>
                <box><bottomPen lineWidth="1.0"/></box>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Booking #]]></text>
            </staticText>
            <staticText>
                <reportElement x="60" y="0" width="150" height="20"/>
                <box><bottomPen lineWidth="1.0"/></box>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Guest]]></text>
            </staticText>
            <staticText>
                <reportElement x="210" y="0" width="70" height="20"/>
                <box><bottomPen lineWidth="1.0"/></box>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Room]]></text>
            </staticText>
            <staticText>
                <reportElement x="280" y="0" width="90" height="20"/>
                <box><bottomPen lineWidth="1.0"/></box>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Check-in]]></text>
            </staticText>
            <staticText>
                <reportElement x="370" y="0" width="90" height="20"/>
                <box><bottomPen lineWidth="1.0"/></box>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Check-out]]></text>
            </staticText>
            <staticText>
                <reportElement x="460" y="0" width="100" height="20"/>
                <box><bottomPen lineWidth="1.0"/></box>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Payment Method]]></text>
            </staticText>
            <staticText>
                <reportElement x="560" y="0" width="110" height="20"/>
                <box><bottomPen lineWidth="1.0"/></box>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Payment Date]]></text>
            </staticText>
            <staticText>
                <reportElement x="670" y="0" width="112" height="20"/>
                <box><bottomPen lineWidth="1.0"/></box>
                <textElement textAlignment="Right"><font isBold="true"/></textElement>
                <text><![CDATA[Amount (Rs.)]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="60" height="18"/>
                <textFieldExpression><![CDATA[$F{booking_id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="60" y="0" width="150" height="18"/>
                <textFieldExpression><![CDATA[$F{guest_name}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="210" y="0" width="70" height="18"/>
                <textFieldExpression><![CDATA[$F{room_number}]]></textFieldExpression>
            </textField>
            <textField pattern="dd-MMM-yyyy">
                <reportElement x="280" y="0" width="90" height="18"/>
                <textFieldExpression><![CDATA[$F{check_in_date}]]></textFieldExpression>
            </textField>
            <textField pattern="dd-MMM-yyyy">
                <reportElement x="370" y="0" width="90" height="18"/>
                <textFieldExpression><![CDATA[$F{check_out_date}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="460" y="0" width="100" height="18"/>
                <textFieldExpression><![CDATA[$F{payment_method}]]></textFieldExpression>
            </textField>
            <textField pattern="dd-MMM-yyyy HH:mm">
                <reportElement x="560" y="0" width="110" height="18"/>
                <textFieldExpression><![CDATA[$F{payment_date}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="670" y="0" width="112" height="18"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$F{payment_amount}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="30">
            <line>
                <reportElement x="560" y="0" width="222" height="1"/>
            </line>
            <staticText>
                <reportElement x="560" y="5" width="110" height="20"/>
                <textElement textAlignment="Right"><font isBold="true"/></textElement>
                <text><![CDATA[Total Revenue:]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="670" y="5" width="112" height="20"/>
                <textElement textAlignment="Right"><font isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{REVENUE_SUM}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
